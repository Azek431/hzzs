{
  "files.encoding": "utf8",
  "files.eol": "\n",
  "files.insertFinalNewline": true,
  "files.trimTrailingWhitespace": true,

  "editor.formatOnSave": false,
  "editor.formatOnPaste": false,
  "editor.largeFileOptimizations": true,
  "editor.minimap.enabled": false,
  "editor.codeLens": false,
  "editor.stickyScroll.enabled": false,
  "editor.smoothScrolling": false,
  "editor.hover.delay": 800,
  "editor.inlayHints.enabled": "off",
  "editor.lightbulb.enabled": "off",

  "breadcrumbs.enabled": false,
  "workbench.list.smoothScrolling": false,
  "workbench.editor.enablePreview": true,
  "workbench.editor.restoreViewState": false,
  "workbench.startupEditor": "none",

  "extensions.ignoreRecommendations": true,
  "extensions.autoCheckUpdates": false,

  "files.exclude": {
    "**/.git": true,
    "**/.gradle": true,
    "**/.idea": true,
    "**/.kotlin": true,
    "**/build": true,
    "**/app/build": true,
    "**/.cxx": true,
    "**/.externalNativeBuild": true,
    "**/captures": true,
    "**/node_modules": true,
    "**/.stfolder": true,
    "**/dist": true,
    "**/out": true,
    "**/.cache": true,
    "**/.vite": true,
    "**/.astro": true,
    "**/*.log": true,
    "**/*.tmp": true,
    "**/*.apk": true,
    "**/*.aab": true,
    "**/*.dex": true,
    "**/*.class": true,
    "**/*.o": true,
    "**/*.so": true,
    "**/.DS_Store": true,
    "**/Thumbs.db": true
  },

  "search.exclude": {
    "**/.git": true,
    "**/.gradle": true,
    "**/.idea": true,
    "**/.kotlin": true,
    "**/build": true,
    "**/app/build": true,
    "**/.cxx": true,
    "**/.externalNativeBuild": true,
    "**/captures": true,
    "**/node_modules": true,
    "**/.stfolder": true,
    "**/dist": true,
    "**/out": true,
    "**/.cache": true,
    "**/.vite": true,
    "**/.astro": true,
    "**/*.log": true,
    "**/*.tmp": true,
    "**/*.apk": true,
    "**/*.aab": true,
    "**/*.dex": true,
    "**/*.class": true,
    "**/*.o": true,
    "**/*.so": true,
    "**/.DS_Store": true,
    "**/Thumbs.db": true
  },

  "files.watcherExclude": {
    "**/.git/objects/**": true,
    "**/.git/subtree-cache/**": true,
    "**/.gradle/**": true,
    "**/.idea/**": true,
    "**/.kotlin/**": true,
    "**/build/**": true,
    "**/app/build/**": true,
    "**/.cxx/**": true,
    "**/.externalNativeBuild/**": true,
    "**/captures/**": true,
    "**/node_modules/**": true,
    "**/.stfolder/**": true,
    "**/dist/**": true,
    "**/out/**": true,
    "**/.cache/**": true,
    "**/.vite/**": true,
    "**/.astro/**": true,
    "**/*.log": true,
    "**/*.tmp": true,
    "**/*.apk": true,
    "**/*.aab": true,
    "**/*.dex": true,
    "**/*.class": true,
    "**/*.o": true,
    "**/*.so": true,
    "**/.DS_Store": true,
    "**/Thumbs.db": true
  },

  "search.followSymlinks": false,

  "git.openRepositoryInParentFolders": "never",
  "git.autofetch": false,
  "git.autorefresh": false,
  "git.decorations.enabled": false,
  "git.confirmBeforeClose": false,

  "terminal.integrated.cwd": "${workspaceFolder}",
  "terminal.integrated.defaultProfile.windows": "PowerShell",

  "java.import.gradle.enabled": false,
  "java.gradle.buildServer.enabled": "off",
  "java.autobuild.enabled": false,
  "java.maxConcurrentBuilds": 1,
  "java.configuration.updateBuildConfiguration": "disabled",
  "java.referencesCodeLens.enabled": false,
  "java.implementationsCodeLens.enabled": false,
  "java.signatureHelp.enabled": false,
  "java.completion.importOrder": [],
  "java.jdt.ls.vmargs": "-Xmx512m -XX:MaxMetaspaceSize=192m -XX:+UseG1GC -XX:G1HeapRegionSize=4m -XX:+UseStringDeduplication",
  "java.server.launchMode": "StandardIO",

  "eslint.enable": false,
  "cSpell.enabled": false,
  "auto-rename-tag.activationOnLanguage": [],

  "[kotlin]": {
    "editor.insertSpaces": true,
    "editor.tabSize": 4
  },
  "[xml]": {
    "editor.insertSpaces": true,
    "editor.tabSize": 4
  },
  "[json]": {
    "editor.insertSpaces": true,
    "editor.tabSize": 2
  },

  "cSpell.words": [
    "androidx",
    "appcompat",
    "myapplication",
    "optimizationpasses",
    "proguard"
  ]
}
