{
  "version": "2.0.0",
  "options": {
    "cwd": "${workspaceFolder}",
    "env": {
      "CMAKE_BUILD_PARALLEL_LEVEL": "2"
    }
  },
  "tasks": [
    {
      "label": "🔨 [HZZS] 构建 Debug APK",
      "detail": "assembleDebug，不安装。日常确认能否编译。包名将是 top.azek431.hzzs.debug。",
      "type": "shell",
      "command": ".\\gradlew.bat",
      "args": [
        "--console=plain",
        ":app:assembleDebug"
      ],
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "problemMatcher": [],
      "runOptions": {
        "instanceLimit": 1
      },
      "presentation": {
        "reveal": "always",
        "focus": false,
        "panel": "shared",
        "clear": true,
        "showReuseMessage": false,
        "group": "hzzs-build"
      }
    },
    {
      "label": "📲 [HZZS] 安装 Debug APK",
      "detail": "installDebug：构建并安装到已连接设备。安装身份 top.azek431.hzzs.debug。",
      "type": "shell",
      "command": ".\\gradlew.bat",
      "args": [
        "--console=plain",
        ":app:installDebug"
      ],
      "problemMatcher": [],
      "runOptions": {
        "instanceLimit": 1
      },
      "presentation": {
        "reveal": "always",
        "focus": false,
        "panel": "shared",
        "clear": true,
        "showReuseMessage": false,
        "group": "hzzs-build"
      }
    },
    {
      "label": "▶️ [HZZS] 启动 Debug 应用",
      "detail": "启动 top.azek431.hzzs.debug。优先 am start 组件，失败再 monkey。",
      "type": "process",
      "command": "powershell.exe",
      "args": [
        "-NoLogo",
        "-NoProfile",
        "-NonInteractive",
        "-ExecutionPolicy",
        "Bypass",
        "-File",
        "${workspaceFolder}/.vscode/scripts/hzzs-launch-app.ps1",
        "-Flavor",
        "debug"
      ],
      "problemMatcher": [],
      "presentation": {
        "reveal": "always",
        "focus": false,
        "panel": "dedicated",
        "clear": true,
        "showReuseMessage": false,
        "group": "hzzs-device"
      }
    },
    {
      "label": "▶️ [HZZS] 启动 Release 应用",
      "detail": "启动正式包 top.azek431.hzzs。仅当设备已装 Release 时使用。",
      "type": "process",
      "command": "powershell.exe",
      "args": [
        "-NoLogo",
        "-NoProfile",
        "-NonInteractive",
        "-ExecutionPolicy",
        "Bypass",
        "-File",
        "${workspaceFolder}/.vscode/scripts/hzzs-launch-app.ps1",
        "-Flavor",
        "release"
      ],
      "problemMatcher": [],
      "presentation": {
        "reveal": "always",
        "focus": false,
        "panel": "dedicated",
        "clear": true,
        "showReuseMessage": false,
        "group": "hzzs-device"
      }
    },
    {
      "label": "🚀 [HZZS] 构建、安装并启动 Debug",
      "detail": "一条龙：installDebug → 启动 Debug 包。日常真机验证首选。",
      "dependsOrder": "sequence",
      "dependsOn": [
        "📲 [HZZS] 安装 Debug APK",
        "▶️ [HZZS] 启动 Debug 应用"
      ],
      "problemMatcher": [],
      "runOptions": {
        "instanceLimit": 1
      },
      "presentation": {
        "reveal": "always",
        "focus": true,
        "panel": "dedicated",
        "clear": true,
        "showReuseMessage": false,
        "group": "hzzs-device"
      }
    },
    {
      "label": "🩺 [HZZS] 检查设备与包状态",
      "detail": "只读：ADB 设备、Debug/Release 安装路径、PID、LAUNCHER 解析。",
      "type": "process",
      "command": "powershell.exe",
      "args": [
        "-NoLogo",
        "-NoProfile",
        "-NonInteractive",
        "-ExecutionPolicy",
        "Bypass",
        "-File",
        "${workspaceFolder}/.vscode/scripts/hzzs-device-status.ps1"
      ],
      "problemMatcher": [],
      "presentation": {
        "reveal": "always",
        "focus": true,
        "panel": "dedicated",
        "clear": true,
        "showReuseMessage": false,
        "group": "hzzs-device"
      }
    },
    {
      "label": "⏹️ [HZZS] 强制停止 Debug 应用",
      "detail": "am force-stop top.azek431.hzzs.debug，不卸载、不清数据。",
      "type": "process",
      "command": "powershell.exe",
      "args": [
        "-NoLogo",
        "-NoProfile",
        "-NonInteractive",
        "-ExecutionPolicy",
        "Bypass",
        "-File",
        "${workspaceFolder}/.vscode/scripts/hzzs-package-action.ps1",
        "-Flavor",
        "debug",
        "-Action",
        "force-stop"
      ],
      "problemMatcher": [],
      "presentation": {
        "reveal": "always",
        "focus": false,
        "panel": "dedicated",
        "clear": true,
        "showReuseMessage": false,
        "group": "hzzs-device"
      }
    },
    {
      "label": "🧽 [HZZS] 清空 logcat",
      "detail": "adb logcat -c。真机复现前先清缓冲。",
      "type": "shell",
      "command": "adb",
      "args": [
        "logcat",
        "-c"
      ],
      "problemMatcher": [],
      "presentation": {
        "reveal": "always",
        "focus": false,
        "panel": "dedicated",
        "clear": true,
        "showReuseMessage": false,
        "group": "hzzs-log"
      }
    },
    {
      "label": "🐞 [HZZS] 监听核心 logcat",
      "detail": "长任务，需在终端面板手动停止（垃圾桶/停止按钮）。过滤 HZZS / 崩溃 / Activity / Window。不要放进 dependsOn 复合任务，否则会永远不结束。",
      "type": "shell",
      "command": "adb",
      "args": [
        "logcat",
        "-v",
        "time",
        "HZZS:D",
        "AndroidRuntime:E",
        "System.err:E",
        "ActivityManager:I",
        "ActivityTaskManager:I",
        "WindowManager:I",
        "*:S"
      ],
      "problemMatcher": [],
      "runOptions": {
        "instanceLimit": 1
      },
      "presentation": {
        "reveal": "always",
        "focus": true,
        "panel": "dedicated",
        "clear": true,
        "showReuseMessage": false,
        "group": "hzzs-log"
      }
    },
    {
      "label": "🧪 [HZZS] 真机诊断一条龙",
      "detail": "清 logcat → 安装 Debug → 启动 Debug。不会自动挂 logcat（长任务请另开「监听核心 logcat」）。",
      "dependsOrder": "sequence",
      "dependsOn": [
        "🧽 [HZZS] 清空 logcat",
        "📲 [HZZS] 安装 Debug APK",
        "▶️ [HZZS] 启动 Debug 应用"
      ],
      "problemMatcher": [],
      "runOptions": {
        "instanceLimit": 1
      },
      "presentation": {
        "reveal": "always",
        "focus": true,
        "panel": "dedicated",
        "clear": true,
        "showReuseMessage": false,
        "group": "hzzs-log"
      }
    },
    {
      "label": "📤 [HZZS] 导出诊断快照",
      "detail": "导出到 D:\\Azek431-Archives\\hzzs-device-diagnostics（设备信息、双包状态、logcat、截图）。",
      "type": "process",
      "command": "powershell.exe",
      "args": [
        "-NoLogo",
        "-NoProfile",
        "-NonInteractive",
        "-ExecutionPolicy",
        "Bypass",
        "-File",
        "${workspaceFolder}/.vscode/scripts/hzzs-export-diagnostics.ps1"
      ],
      "problemMatcher": [],
      "presentation": {
        "reveal": "always",
        "focus": true,
        "panel": "dedicated",
        "clear": true,
        "showReuseMessage": false,
        "group": "hzzs-log"
      }
    },
    {
      "label": "🔌 [HZZS] 调试前置：安装+启动+JDWP",
      "detail": "launch.json preLaunchTask：installDebug → 启动 Debug → forward tcp:5005 jdwp。",
      "type": "process",
      "command": "powershell.exe",
      "args": [
        "-NoLogo",
        "-NoProfile",
        "-NonInteractive",
        "-ExecutionPolicy",
        "Bypass",
        "-File",
        "${workspaceFolder}/.vscode/scripts/hzzs-jdwp-prepare.ps1"
      ],
      "problemMatcher": [],
      "runOptions": {
        "instanceLimit": 1
      },
      "presentation": {
        "reveal": "always",
        "focus": true,
        "panel": "dedicated",
        "clear": true,
        "showReuseMessage": false,
        "group": "hzzs-debug"
      }
    },
    {
      "label": "🔌 [HZZS] 仅转发 JDWP（已在运行）",
      "detail": "应用已在跑时：跳过安装，只启动/附着并 forward 5005。",
      "type": "process",
      "command": "powershell.exe",
      "args": [
        "-NoLogo",
        "-NoProfile",
        "-NonInteractive",
        "-ExecutionPolicy",
        "Bypass",
        "-File",
        "${workspaceFolder}/.vscode/scripts/hzzs-jdwp-prepare.ps1",
        "-SkipInstall"
      ],
      "problemMatcher": [],
      "runOptions": {
        "instanceLimit": 1
      },
      "presentation": {
        "reveal": "always",
        "focus": true,
        "panel": "dedicated",
        "clear": true,
        "showReuseMessage": false,
        "group": "hzzs-debug"
      }
    },
    {
      "label": "🔌 [HZZS] 移除 JDWP 转发",
      "detail": "adb forward --remove tcp:5005",
      "type": "shell",
      "command": "adb",
      "args": [
        "forward",
        "--remove",
        "tcp:5005"
      ],
      "problemMatcher": [],
      "presentation": {
        "reveal": "always",
        "focus": false,
        "panel": "dedicated",
        "clear": true,
        "showReuseMessage": false,
        "group": "hzzs-debug"
      }
    },
    {
      "label": "✅ [HZZS] 质量门禁（Python）",
      "detail": "check_resources + check_project + compileall tools。不连设备、不跑 Gradle。",
      "type": "process",
      "command": "powershell.exe",
      "args": [
        "-NoLogo",
        "-NoProfile",
        "-NonInteractive",
        "-ExecutionPolicy",
        "Bypass",
        "-File",
        "${workspaceFolder}/.vscode/scripts/hzzs-quality-gates.ps1"
      ],
      "problemMatcher": [],
      "presentation": {
        "reveal": "always",
        "focus": false,
        "panel": "shared",
        "clear": true,
        "showReuseMessage": false,
        "group": "hzzs-verify"
      }
    },
    {
      "label": "✅ [HZZS] 验证 Debug（构建 + 单元测试）",
      "detail": "assembleDebug + testDebugUnitTest。提交前快速验证。",
      "type": "shell",
      "command": ".\\gradlew.bat",
      "args": [
        "--console=plain",
        ":app:assembleDebug",
        ":app:testDebugUnitTest"
      ],
      "group": {
        "kind": "test",
        "isDefault": true
      },
      "problemMatcher": [],
      "runOptions": {
        "instanceLimit": 1
      },
      "presentation": {
        "reveal": "always",
        "focus": false,
        "panel": "shared",
        "clear": true,
        "showReuseMessage": false,
        "group": "hzzs-verify"
      }
    },
    {
      "label": "🛡️ [HZZS] 提交前完整验证",
      "detail": "assembleDebug + testDebugUnitTest + lintDebug。最完整、最慢。",
      "type": "shell",
      "command": ".\\gradlew.bat",
      "args": [
        "--console=plain",
        ":app:assembleDebug",
        ":app:testDebugUnitTest",
        ":app:lintDebug"
      ],
      "problemMatcher": [],
      "runOptions": {
        "instanceLimit": 1
      },
      "presentation": {
        "reveal": "always",
        "focus": false,
        "panel": "shared",
        "clear": true,
        "showReuseMessage": false,
        "group": "hzzs-verify"
      }
    },
    {
      "label": "🗑️ [HZZS] 卸载 Debug 应用",
      "detail": "卸载 top.azek431.hzzs.debug，清除该包数据。",
      "type": "process",
      "command": "powershell.exe",
      "args": [
        "-NoLogo",
        "-NoProfile",
        "-NonInteractive",
        "-ExecutionPolicy",
        "Bypass",
        "-File",
        "${workspaceFolder}/.vscode/scripts/hzzs-package-action.ps1",
        "-Flavor",
        "debug",
        "-Action",
        "uninstall"
      ],
      "problemMatcher": [],
      "presentation": {
        "reveal": "always",
        "focus": true,
        "panel": "dedicated",
        "clear": true,
        "showReuseMessage": false,
        "group": "hzzs-device"
      }
    },
    {
      "label": "🗑️ [HZZS] 卸载 Release 应用",
      "detail": "卸载 top.azek431.hzzs。仅正式包在机时使用。",
      "type": "process",
      "command": "powershell.exe",
      "args": [
        "-NoLogo",
        "-NoProfile",
        "-NonInteractive",
        "-ExecutionPolicy",
        "Bypass",
        "-File",
        "${workspaceFolder}/.vscode/scripts/hzzs-package-action.ps1",
        "-Flavor",
        "release",
        "-Action",
        "uninstall"
      ],
      "problemMatcher": [],
      "presentation": {
        "reveal": "always",
        "focus": true,
        "panel": "dedicated",
        "clear": true,
        "showReuseMessage": false,
        "group": "hzzs-device"
      }
    },
    {
      "label": "🧹 [HZZS] 清除 Debug 应用数据",
      "detail": "pm clear top.azek431.hzzs.debug：重置设置/权限态，不卸载。",
      "type": "process",
      "command": "powershell.exe",
      "args": [
        "-NoLogo",
        "-NoProfile",
        "-NonInteractive",
        "-ExecutionPolicy",
        "Bypass",
        "-File",
        "${workspaceFolder}/.vscode/scripts/hzzs-package-action.ps1",
        "-Flavor",
        "debug",
        "-Action",
        "clear-data"
      ],
      "problemMatcher": [],
      "presentation": {
        "reveal": "always",
        "focus": true,
        "panel": "dedicated",
        "clear": true,
        "showReuseMessage": false,
        "group": "hzzs-device"
      }
    },
    {
      "label": "🛑 [HZZS] 停止 Gradle Daemon",
      "detail": "gradlew --stop，释放本机内存。低内存或构建卡住时用。",
      "type": "shell",
      "command": ".\\gradlew.bat",
      "args": [
        "--console=plain",
        "--stop"
      ],
      "problemMatcher": [],
      "presentation": {
        "reveal": "always",
        "focus": false,
        "panel": "shared",
        "clear": false,
        "showReuseMessage": false,
        "group": "hzzs-build"
      }
    },
    {
      "label": "🧹 [HZZS] Gradle clean（仅故障）",
      "detail": "删除构建产物。日常勿频繁执行，会拖慢下次构建。",
      "type": "shell",
      "command": ".\\gradlew.bat",
      "args": [
        "--console=plain",
        "clean"
      ],
      "problemMatcher": [],
      "runOptions": {
        "instanceLimit": 1
      },
      "presentation": {
        "reveal": "always",
        "focus": false,
        "panel": "shared",
        "clear": true,
        "showReuseMessage": false,
        "group": "hzzs-build"
      }
    },
    {
      "label": "🔎 [HZZS] Git 状态与最近提交",
      "detail": "只读：git status --short 与 log -10。不修改仓库。",
      "type": "process",
      "command": "powershell.exe",
      "args": [
        "-NoLogo",
        "-NoProfile",
        "-NonInteractive",
        "-ExecutionPolicy",
        "Bypass",
        "-Command",
        "Write-Host '========== git status --short =========='; git status --short --untracked-files=all; Write-Host ''; Write-Host '========== git log --oneline -10 =========='; git log --oneline -10"
      ],
      "problemMatcher": [],
      "presentation": {
        "reveal": "always",
        "focus": true,
        "panel": "dedicated",
        "clear": true,
        "showReuseMessage": false,
        "group": "hzzs-meta"
      }
    }
  ]
}
