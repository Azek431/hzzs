# ============================================================
# HZZS（火崽崽数据分析）- Git 忽略规则
# ============================================================
#
# 项目定位：
# - Android 原生：Kotlin + Jetpack Compose + Hilt + C++17/JNI
# - 单模块 app/；根目录保留 Gradle、CI、tools、文档
# - Android Studio / VS Code + Claude Code 协作
# - Windows / Linux；可能通过 Syncthing 同步工作目录
#
# 核心原则：
# 1. 提交：源码、资源、Gradle Wrapper、共享配置、文档、质量脚本。
# 2. 忽略：构建产物、本机缓存、SDK 路径、IDE 私有状态、日志、密钥、
#    本地备份、拷机 APK、AI 本机权限配置。
# 3. 白名单：.vscode 共享配置、CLAUDE.md、AGENTS.md、.serena 项目配置、
#    .github/ 工作流。
#
# 重要说明：
# - .gitignore 只影响“尚未被 Git 跟踪”的文件。
# - 已跟踪文件需用 `git rm --cached` 停止跟踪，不会改写历史。
# - Syncthing 排除规则写在本机 .stignore，不由本文件控制。
# ============================================================


# ============================================================
# 1. Gradle 缓存与 Android 构建产物
# ============================================================

/.gradle/
/build/
**/build/
/.kotlin/
/out/
*.class

# 本地导出的可安装包（手动拷机用，不入库）
/dist/

# CMake / NDK / externalNativeBuild 中间产物
/.cxx/
**/.cxx/
/.externalNativeBuild/
**/.externalNativeBuild/
/app/.cxx/


# ============================================================
# 2. Android SDK、本机路径与 IDE 本地状态
# ============================================================

/local.properties
/.idea/
*.iml
*.ipr
*.iws
/captures/
*.hprof
*.trace


# ============================================================
# 3. 打包、安装与发布生成物
# ============================================================

*.apk
*.aab
*.apks
*.ap_
*.idsig
*.hzzsdelta
*.hzzsalg
output-metadata.json


# ============================================================
# 4. 签名文件、密钥与发布私密配置
# ============================================================

*.jks
*.keystore
*.p12
*.pfx
/key.properties
/keystore.properties
/signing.properties
/secrets.properties
/local.secrets.properties
/keystore/
/keys/
/secrets/
/app/google-services.json


# ============================================================
# 5. 环境变量与本机私有配置
# ============================================================

/.env
/.env.*
!/.env.example
!/.env.sample
!/.env.template
!/.env.*.example

# 私人机器专用 Gradle 覆盖（共享 gradle.properties 仍提交）
/gradle.local.properties
/gradle-local.properties
/gradle/gradle-daemon-jvm.properties.backup-*


# ============================================================
# 6. VS Code 共享配置与本机局部配置
# ============================================================

/.vscode/*
!/.vscode/settings.json
!/.vscode/tasks.json
!/.vscode/launch.json
!/.vscode/extensions.json
!/.vscode/*.code-snippets
/.vscode/*.local.json
/.vscode/*.local.*
/.vscode/settings.local.json
/.vscode/*.log


# ============================================================
# 7. Claude Code、Serena 与 AI 协作本地文件
# ============================================================
#
# 提交：CLAUDE.md、AGENTS.md、.serena/project.yml 等共享规则。
# 忽略：本机权限、状态栏、私人设置、技能锁与本地缓存。

/.claude/settings.json
/.claude/settings.local.json
/.claude/*.local.json
/.claude/*.local.md
/.claude/cache/
/CLAUDE.local.md
/skills-lock.json
/.history/


# ============================================================
# 8. Syncthing 内部文件与冲突副本
# ============================================================
#
# 下列规则只防 Git 提交；同步排除写本机 .stignore。
# 不忽略 .git/：跨设备可同步仓库，但勿两机同时重写历史。

/.stfolder/
/.stfolder.removed-*
/.stversions/
/.stignore
~syncthing~*.tmp
.syncthing*.tmp
*.sync-conflict-*


# ============================================================
# 9. Node.js / 前端辅助缓存（若后续加入文档站/脚本）
# ============================================================

/node_modules/
/.pnpm-store/
/.npm/
/.yarn/
/.pnp.*
/.parcel-cache/
/.turbo/
/.vite/
/.cache/
npm-debug.log*
pnpm-debug.log*
yarn-debug.log*
yarn-error.log*


# ============================================================
# 10. Python 质量/视觉脚本缓存
# ============================================================
#
# tools/quality、tools/vision、tools/release、tools/algorithm 使用 Python。

__pycache__/
*.py[cod]
.pytest_cache/
.mypy_cache/
.ruff_cache/
.venv/
venv/


# ============================================================
# 11. 测试报告、本地诊断与备份目录
# ============================================================

/coverage/
/test-results/
/playwright-report/
/.nyc_output/
/.hzzs-test-results/
.hzzs-test-results/
/.backups/
.backups/
/hzzs-lint-errors*.txt
hzzs-lint-errors*.txt


# ============================================================
# 12. 日志、临时文件、编辑器备份
# ============================================================

*.log
hs_err_pid*.log
replay_pid*.log
*.tmp
*.temp
*.bak
*.old
*.orig
*.rej
*.swp
*.swo
*~


# ============================================================
# 13. 操作系统垃圾文件
# ============================================================

Thumbs.db
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/
.DS_Store
.DS_Store?
._*
.AppleDouble
.LSOverride
.Spotlight-V100
.Trashes
.directory
.Trash-*/


# ============================================================
# 14. 原生库编译产物
# ============================================================

*.so
*.o
*.a
*.dll
*.dylib
