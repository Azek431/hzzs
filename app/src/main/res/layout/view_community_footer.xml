<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginTop="30dp"
    android:gravity="center_horizontal"
    android:orientation="vertical">

    <View
        android:layout_width="52dp"
        android:layout_height="1dp"
        android:background="#42FFFFFF" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:text="@string/community_footer_heading"
        android:textColor="#FF948B91"
        android:textSize="11sp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/textCommunityQqLink"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:background="@drawable/bg_community_footer_link"
        android:clickable="true"
        android:contentDescription="@string/community_qq_content_description"
        android:focusable="true"
        android:gravity="center"
        android:minHeight="44dp"
        android:paddingStart="10dp"
        android:paddingEnd="10dp"
        android:text="@string/community_footer_qq"
        android:textColor="#FFFFB1C4"
        android:textSize="13sp" />

    <TextView
        android:id="@+id/textCommunityTelegramLink"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="2dp"
        android:background="@drawable/bg_community_footer_link"
        android:clickable="true"
        android:contentDescription="@string/community_telegram_content_description"
        android:focusable="true"
        android:gravity="center"
        android:minHeight="44dp"
        android:paddingStart="10dp"
        android:paddingEnd="10dp"
        android:text="@string/community_footer_telegram"
        android:textColor="#FFCFC4CA"
        android:textSize="12sp" />

</LinearLayout>
