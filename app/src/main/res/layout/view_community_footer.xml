<?xml version="1.0" encoding="utf-8"?>
<!--
    社区链接页脚布局。

    包含：
    - 分区标题（交流与动态）
    - QQ 群链接（可点击，跳转或复制）
    - Telegram 频道链接（可点击，跳转或复制）

    此布局通过 <include layout="@layout/view_community_footer" />
    在 activity_main.xml 中引用，android:id="@+id/communityFooter"
    使 include 容器可以被 ViewCompat.setOnApplyWindowInsetsListener 等
    方法引用。
-->
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:gravity="center_horizontal"
    android:orientation="vertical"
    android:paddingTop="@dimen/space_xl"
    android:paddingBottom="@dimen/space_sm">

    <!-- 分区标题 -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/space_lg"
        android:text="@string/community_footer_heading"
        android:textColor="@color/outline"
        android:textSize="@dimen/text_footer_small"
        android:textStyle="bold" />

    <!-- QQ 群链接 -->
    <TextView
        android:id="@+id/textCommunityQqLink"
        android:layout_width="wrap_content"
        android:layout_height="40dp"
        android:layout_marginTop="@dimen/space_sm"
        android:background="@drawable/bg_community_footer_link"
        android:clickable="true"
        android:contentDescription="@string/community_qq_content_description"
        android:ellipsize="end"
        android:focusable="true"
        android:gravity="center"
        android:includeFontPadding="false"
        android:maxLines="1"
        android:paddingStart="@dimen/space_sm"
        android:paddingEnd="@dimen/space_sm"
        android:text="@string/community_footer_qq"
        android:textColor="@color/brand_primary"
        android:textSize="@dimen/text_footer" />

    <!-- Telegram 频道链接 -->
    <TextView
        android:id="@+id/textCommunityTelegramLink"
        android:layout_width="wrap_content"
        android:layout_height="38dp"
        android:layout_marginTop="@dimen/space_2xs"
        android:background="@drawable/bg_community_footer_link"
        android:clickable="true"
        android:contentDescription="@string/community_telegram_content_description"
        android:ellipsize="end"
        android:focusable="true"
        android:gravity="center"
        android:includeFontPadding="false"
        android:maxLines="1"
        android:paddingStart="@dimen/space_sm"
        android:paddingEnd="@dimen/space_sm"
        android:text="@string/community_footer_telegram"
        android:textColor="@color/on_surface_variant"
        android:textSize="@dimen/text_footer" />

</LinearLayout>
