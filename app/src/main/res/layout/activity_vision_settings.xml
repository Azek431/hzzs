<?xml version="1.0" encoding="utf-8"?>
<!--
    视觉识别设置页面布局。

    整体结构：
    1. AppBarLayout → 顶部标题栏（ActionBar 显示设置标题）
    2. TabLayout → 分区导航标签（5 个分区横向滑动）
    3. ViewPager2 → 分区内容容器（每个分区一个 SettingsFragment）
    4. 底部操作栏 → 恢复默认 + 保存按钮

    设计规范：
    - 使用 Surface 暖白背景 #FFF8F6，与首页保持一致
    - TabLayout 使用品牌色 #C73650 作为指示器
    - 底部操作栏使用 surface_container_high 背景色 + 顶部阴影
    - 卡片圆角统一 16dp，内边距 20dp
-->
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/rootContainer"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/surface_background">

    <!-- 顶部 TabLayout 区域 -->
    <com.google.android.material.tabs.TabLayout
        android:id="@+id/tabLayout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/surface"
        app:tabIndicatorColor="@color/brand_primary"
        app:tabIndicatorFullWidth="false"
        app:tabIndicatorHeight="3dp"
        app:tabMode="fixed"
        app:tabSelectedTextColor="@color/brand_primary"
        app:tabTextAppearance="@style/SettingsTabTextAppearance"
        app:tabTextColor="@color/on_surface_variant" />

    <!-- ViewPager2 内容区域 -->
    <androidx.viewpager2.widget.ViewPager2
        android:id="@+id/viewPager"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:layout_above="@id/bottomBar" />

    <!-- 底部操作栏 -->
    <LinearLayout
        android:id="@+id/bottomBar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_alignParentBottom="true"
        android:background="@color/surface_container_high"
        android:elevation="8dp"
        android:orientation="horizontal"
        android:paddingStart="@dimen/page_padding_horizontal"
        android:paddingTop="@dimen/space_md"
        android:paddingEnd="@dimen/page_padding_horizontal"
        android:paddingBottom="@dimen/space_md">

        <!-- 恢复默认按钮 -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnReset"
            style="@style/Widget.Material3.Button.OutlinedButton"
            android:layout_width="0dp"
            android:layout_height="@dimen/button_min_height"
            android:layout_weight="1"
            android:layout_marginEnd="@dimen/space_sm"
            android:text="@string/settings_reset"
            android:textColor="@color/on_surface_variant"
            app:cornerRadius="@dimen/radius_medium"
            app:icon="@drawable/ic_restore_24"
            app:iconGravity="textStart"
            app:iconPadding="@dimen/space_xs"
            app:iconTint="@color/on_surface_variant"
            app:strokeColor="@color/outline" />

        <!-- 保存按钮 -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnSave"
            android:layout_width="0dp"
            android:layout_height="@dimen/button_min_height"
            android:layout_weight="1"
            android:layout_marginStart="@dimen/space_sm"
            android:text="@string/settings_save"
            android:textColor="@color/brand_on_primary"
            app:cornerRadius="@dimen/radius_medium" />

    </LinearLayout>

</androidx.coordinatorlayout.widget.CoordinatorLayout>
