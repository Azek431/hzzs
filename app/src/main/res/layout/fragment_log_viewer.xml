<?xml version="1.0" encoding="utf-8"?>
<!-- 综合日志查看页面布局 -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="12dp"
    android:background="#1a1a2e">

    <!-- 标题栏 -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="📋 综合日志中心"
        android:textColor="#5CB8FF"
        android:textSize="16sp"
        android:textStyle="bold"
        android:paddingBottom="8dp" />

    <!-- 筛选栏：级别 + 标签 + 搜索 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingBottom="6dp">

        <!-- 级别筛选 Spinner -->
        <Spinner
            android:id="@+id/spinnerLevel"
            android:layout_width="wrap_content"
            android:layout_height="36dp"
            android:minWidth="80dp" />

        <!-- 标签筛选 Spinner -->
        <Spinner
            android:id="@+id/spinnerTag"
            android:layout_width="wrap_content"
            android:layout_height="36dp"
            android:minWidth="80dp"
            android:layout_marginStart="8dp" />

        <!-- 搜索框 -->
        <EditText
            android:id="@+id/etSearch"
            android:layout_width="0dp"
            android:layout_height="36dp"
            android:layout_weight="1"
            android:layout_marginStart="8dp"
            android:background="@android:drawable/edit_text"
            android:hint="搜索日志..."
            android:imeOptions="actionSearch"
            android:inputType="text"
            android:paddingStart="8dp"
            android:paddingEnd="8dp"
            android:textSize="12sp" />
    </LinearLayout>

    <!-- 按钮栏 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center"
        android:paddingBottom="6dp">

        <Button
            android:id="@+id/btnAutoRefresh"
            android:layout_width="wrap_content"
            android:layout_height="36dp"
            android:text="自动刷新: 关"
            android:textSize="11sp"
            android:backgroundTint="#3A7DDC" />

        <Button
            android:id="@+id/btnManualRefresh"
            android:layout_width="wrap_content"
            android:layout_height="36dp"
            android:text="手动刷新"
            android:textSize="11sp"
            android:layout_marginStart="8dp"
            android:backgroundTint="#3A7DDC" />

        <Button
            android:id="@+id/btnExportTxt"
            android:layout_width="wrap_content"
            android:layout_height="36dp"
            android:text="TXT"
            android:textSize="11sp"
            android:layout_marginStart="8dp"
            android:backgroundTint="#3A7DDC" />

        <Button
            android:id="@+id/btnExportCsv"
            android:layout_width="wrap_content"
            android:layout_height="36dp"
            android:text="CSV"
            android:textSize="11sp"
            android:layout_marginStart="4dp"
            android:backgroundTint="#3A7DDC" />

        <Button
            android:id="@+id/btnCopyLog"
            android:layout_width="wrap_content"
            android:layout_height="36dp"
            android:text="复制"
            android:textSize="11sp"
            android:layout_marginStart="4dp"
            android:backgroundTint="#3A7DDC" />

        <Button
            android:id="@+id/btnClearLog"
            android:layout_width="wrap_content"
            android:layout_height="36dp"
            android:text="清空"
            android:textSize="11sp"
            android:layout_marginStart="8dp"
            android:backgroundTint="#DC3545" />
    </LinearLayout>

    <!-- 日志统计栏 -->
    <TextView
        android:id="@+id/tvLogStats"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="日志: 0 条"
        android:textColor="#888888"
        android:textSize="10sp"
        android:paddingBottom="4dp" />

    <!-- 日志列表（RecyclerView 风格，用 TextView 逐行显示） -->
    <ScrollView
        android:id="@+id/logScrollView"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:background="#0d1117"
        android:padding="8dp"
        android:elevation="2dp">

        <LinearLayout
            android:id="@+id/logContainer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical" />
    </ScrollView>

    <!-- C++ 视觉算法日志区域（可折叠） -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingTop="8dp"
        android:paddingBottom="4dp">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="▼ C++ 算法原始日志 ▼"
            android:textColor="#5CB8FF"
            android:textSize="12sp"
            android:textStyle="bold" />

        <Button
            android:id="@+id/btnCollapseCppLog"
            android:layout_width="wrap_content"
            android:layout_height="30dp"
            android:text="收起"
            android:textSize="10sp"
            android:backgroundTint="#3A7DDC" />
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="vertical"
        android:id="@+id/cppLogContainer">

        <ScrollView
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="#0d1117"
            android:padding="8dp">

            <TextView
                android:id="@+id/cppLogTextView"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="#C9D1D9"
                android:textSize="11sp"
                android:fontFamily="monospace"
                android:lineSpacingExtra="2dp" />
        </ScrollView>
    </LinearLayout>
</LinearLayout>
