<?xml version="1.0" encoding="utf-8"?>
<!--
    设置分区 Fragment 布局。

    每个分区（识别与截图 / HUD 显示 / 玩家与绿瓶 / 检测参数 / 调试选项）
    共用此布局：顶部标题 Chip + 可滚动的参数列表。
-->
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/surface_background"
    android:orientation="vertical">

    <!-- 分区标题栏 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingStart="@dimen/page_padding_horizontal"
        android:paddingTop="@dimen/space_lg"
        android:paddingEnd="@dimen/page_padding_horizontal"
        android:paddingBottom="@dimen/space_md">

        <!-- 分区标题图标 -->
        <ImageView
            android:id="@+id/sectionIcon"
            android:layout_width="@dimen/feature_icon_container_size"
            android:layout_height="@dimen/feature_icon_container_size"
            android:contentDescription="@null"
            android:src="@drawable/ic_tune_24"
            app:tint="@color/brand_primary" />

        <!-- 分区标题文字 -->
        <TextView
            android:id="@+id/sectionTitle"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="@dimen/space_md"
            android:layout_weight="1"
            android:textSize="@dimen/text_card_title"
            android:textStyle="bold" />

    </LinearLayout>

    <!-- 分隔线 -->
    <View
        android:layout_width="match_parent"
        android:layout_height="@dimen/stroke_width"
        android:background="@color/outline_variant" />

    <!-- 可滚动参数列表 -->
    <ScrollView
        android:id="@+id/settingsScrollView"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:clipToPadding="false"
        android:fillViewport="true"
        android:paddingStart="@dimen/page_padding_horizontal"
        android:paddingEnd="@dimen/page_padding_horizontal"
        android:paddingBottom="@dimen/space_lg">

        <LinearLayout
            android:id="@+id/paramContainer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- 参数行由代码动态添加 -->

        </LinearLayout>

    </ScrollView>

</LinearLayout>
