<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/rootContainer"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/surface_background">

    <com.google.android.material.appbar.AppBarLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/surface_background"
        app:elevation="0dp">

        <LinearLayout
            android:id="@+id/topBarContainer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:minHeight="@dimen/top_bar_min_height"
            android:orientation="vertical"
            android:paddingStart="@dimen/page_padding_horizontal"
            android:paddingTop="@dimen/top_bar_padding_top"
            android:paddingEnd="@dimen/page_padding_horizontal"
            android:paddingBottom="@dimen/top_bar_padding_bottom">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/app_name"
                android:textColor="@color/on_surface"
                android:textSize="@dimen/text_app_title"
                android:textStyle="bold" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/space_2xs"
                android:text="@string/app_subtitle"
                android:textColor="@color/on_surface_variant"
                android:textSize="@dimen/text_app_subtitle" />

        </LinearLayout>
    </com.google.android.material.appbar.AppBarLayout>

    <androidx.core.widget.NestedScrollView
        android:id="@+id/homeScrollView"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:clipToPadding="false"
        android:fillViewport="true"
        android:paddingStart="@dimen/page_padding_horizontal"
        android:paddingTop="@dimen/space_sm"
        android:paddingEnd="@dimen/page_padding_horizontal"
        android:paddingBottom="@dimen/page_padding_bottom"
        app:layout_behavior="@string/appbar_scrolling_view_behavior">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardBackgroundColor="@color/surface_container"
                app:cardCornerRadius="@dimen/radius_large"
                app:cardElevation="0dp"
                app:strokeColor="@color/outline_variant"
                app:strokeWidth="@dimen/stroke_width">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="@dimen/card_padding">

                    <com.google.android.material.chip.Chip
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:checkable="false"
                        android:clickable="false"
                        android:focusable="false"
                        android:text="@string/home_status_preparing"
                        android:textColor="@color/status_preparing_on_container"
                        app:chipBackgroundColor="@color/status_preparing_container"
                        app:chipStrokeColor="@color/status_preparing_outline"
                        app:chipStrokeWidth="@dimen/stroke_width" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/space_lg"
                        android:text="@string/home_hero_title"
                        android:textColor="@color/on_surface"
                        android:textSize="@dimen/text_hero_title"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/space_sm"
                        android:lineSpacingExtra="@dimen/text_line_spacing"
                        android:text="@string/home_hero_description"
                        android:textColor="@color/on_surface_variant"
                        android:textSize="@dimen/text_body" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnDevelopmentPlan"
                        style="@style/Widget.Material3.Button"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:minHeight="@dimen/button_min_height"
                        android:layout_marginTop="@dimen/space_xl"
                        android:text="@string/action_view_development_plan"
                        android:textColor="@color/brand_on_primary"
                        app:backgroundTint="@color/brand_primary"
                        app:cornerRadius="@dimen/radius_medium"
                        app:icon="@drawable/ic_arrow_forward_24"
                        app:iconGravity="textEnd"
                        app:iconPadding="@dimen/space_sm"
                        app:iconTint="@color/brand_on_primary" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnOverlayExecution"
                        style="@style/Widget.Material3.Button.OutlinedButton"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:minHeight="@dimen/button_min_height"
                        android:layout_marginTop="@dimen/space_sm"
                        android:text="@string/action_start_overlay_execution"
                        android:textColor="@color/brand_primary"
                        app:cornerRadius="@dimen/radius_medium"
                        app:icon="@drawable/ic_arrow_forward_24"
                        app:iconGravity="textEnd"
                        app:iconPadding="@dimen/space_sm"
                        app:iconTint="@color/brand_primary"
                        app:strokeColor="@color/brand_primary" />

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/space_2xl"
                android:layout_marginBottom="@dimen/space_md"
                android:text="@string/section_feature_plan"
                android:textColor="@color/on_surface"
                android:textSize="@dimen/text_section_title"
                android:textStyle="bold" />

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="@dimen/space_md"
                android:clickable="false"
                android:focusable="false"
                app:cardBackgroundColor="@color/surface_container_low"
                app:cardCornerRadius="@dimen/radius_medium"
                app:cardElevation="0dp"
                app:strokeColor="@color/outline_variant"
                app:strokeWidth="@dimen/stroke_width">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:padding="@dimen/feature_card_padding">

                    <FrameLayout
                        android:layout_width="@dimen/feature_icon_container_size"
                        android:layout_height="@dimen/feature_icon_container_size"
                        android:background="@drawable/bg_feature_icon_container">

                        <ImageView
                            android:layout_width="@dimen/feature_icon_size"
                            android:layout_height="@dimen/feature_icon_size"
                            android:layout_gravity="center"
                            android:contentDescription="@null"
                            android:src="@drawable/ic_insights_24"
                            app:tint="@color/feature_icon_tint" />

                    </FrameLayout>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="@dimen/space_lg"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="@string/feature_realtime_title"
                            android:textColor="@color/on_surface"
                            android:textSize="@dimen/text_card_title"
                            android:textStyle="bold" />

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="@dimen/space_xs"
                            android:lineSpacingExtra="@dimen/text_line_spacing"
                            android:text="@string/feature_realtime_description"
                            android:textColor="@color/on_surface_variant"
                            android:textSize="@dimen/text_body" />

                    </LinearLayout>

                    <com.google.android.material.chip.Chip
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="@dimen/space_sm"
                        android:checkable="false"
                        android:clickable="false"
                        android:focusable="false"
                        android:text="@string/feature_status_not_enabled"
                        android:textColor="@color/planned_on_container"
                        android:textSize="@dimen/text_label"
                        app:chipBackgroundColor="@color/planned_container"
                        app:chipStrokeColor="@color/planned_outline"
                        app:chipStrokeWidth="@dimen/stroke_width" />

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="@dimen/space_md"
                android:clickable="false"
                android:focusable="false"
                app:cardBackgroundColor="@color/surface_container_low"
                app:cardCornerRadius="@dimen/radius_medium"
                app:cardElevation="0dp"
                app:strokeColor="@color/outline_variant"
                app:strokeWidth="@dimen/stroke_width">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:padding="@dimen/feature_card_padding">

                    <FrameLayout
                        android:layout_width="@dimen/feature_icon_container_size"
                        android:layout_height="@dimen/feature_icon_container_size"
                        android:background="@drawable/bg_feature_icon_container">

                        <ImageView
                            android:layout_width="@dimen/feature_icon_size"
                            android:layout_height="@dimen/feature_icon_size"
                            android:layout_gravity="center"
                            android:contentDescription="@null"
                            android:src="@drawable/ic_report_24"
                            app:tint="@color/feature_icon_tint" />

                    </FrameLayout>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="@dimen/space_lg"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="@string/feature_report_title"
                            android:textColor="@color/on_surface"
                            android:textSize="@dimen/text_card_title"
                            android:textStyle="bold" />

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="@dimen/space_xs"
                            android:lineSpacingExtra="@dimen/text_line_spacing"
                            android:text="@string/feature_report_description"
                            android:textColor="@color/on_surface_variant"
                            android:textSize="@dimen/text_body" />

                    </LinearLayout>

                    <com.google.android.material.chip.Chip
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="@dimen/space_sm"
                        android:checkable="false"
                        android:clickable="false"
                        android:focusable="false"
                        android:text="@string/feature_status_not_enabled"
                        android:textColor="@color/planned_on_container"
                        android:textSize="@dimen/text_label"
                        app:chipBackgroundColor="@color/planned_container"
                        app:chipStrokeColor="@color/planned_outline"
                        app:chipStrokeWidth="@dimen/stroke_width" />

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:clickable="false"
                android:focusable="false"
                app:cardBackgroundColor="@color/surface_container_low"
                app:cardCornerRadius="@dimen/radius_medium"
                app:cardElevation="0dp"
                app:strokeColor="@color/outline_variant"
                app:strokeWidth="@dimen/stroke_width">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:padding="@dimen/feature_card_padding">

                    <FrameLayout
                        android:layout_width="@dimen/feature_icon_container_size"
                        android:layout_height="@dimen/feature_icon_container_size"
                        android:background="@drawable/bg_feature_icon_container">

                        <ImageView
                            android:layout_width="@dimen/feature_icon_size"
                            android:layout_height="@dimen/feature_icon_size"
                            android:layout_gravity="center"
                            android:contentDescription="@null"
                            android:src="@drawable/ic_tune_24"
                            app:tint="@color/feature_icon_tint" />

                    </FrameLayout>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="@dimen/space_lg"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="@string/feature_calibration_title"
                            android:textColor="@color/on_surface"
                            android:textSize="@dimen/text_card_title"
                            android:textStyle="bold" />

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="@dimen/space_xs"
                            android:lineSpacingExtra="@dimen/text_line_spacing"
                            android:text="@string/feature_calibration_description"
                            android:textColor="@color/on_surface_variant"
                            android:textSize="@dimen/text_body" />

                    </LinearLayout>

                    <com.google.android.material.chip.Chip
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="@dimen/space_sm"
                        android:checkable="false"
                        android:clickable="false"
                        android:focusable="false"
                        android:text="@string/feature_status_not_enabled"
                        android:textColor="@color/planned_on_container"
                        android:textSize="@dimen/text_label"
                        app:chipBackgroundColor="@color/planned_container"
                        app:chipStrokeColor="@color/planned_outline"
                        app:chipStrokeWidth="@dimen/stroke_width" />

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <View
                android:layout_width="match_parent"
                android:layout_height="@dimen/stroke_width"
                android:layout_marginTop="@dimen/space_2xl"
                android:background="@color/divider" />

            <!-- 社区链接区域：QQ 群、Telegram 频道 -->
            <include
                android:id="@+id/communityFooter"
                layout="@layout/view_community_footer" />

            <!-- 开发者署名和版本信息 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_horizontal"
                android:orientation="vertical"
                android:paddingTop="@dimen/space_xl"
                android:paddingBottom="@dimen/space_sm">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/footer_developer"
                    android:textColor="@color/on_surface_variant"
                    android:textSize="@dimen/text_footer" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/space_xs"
                    android:text="@string/footer_version"
                    android:textColor="@color/outline"
                    android:textSize="@dimen/text_footer_small" />

            </LinearLayout>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

</androidx.coordinatorlayout.widget.CoordinatorLayout>
