<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/overlayRootPanel"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:clipChildren="false"
    android:clipToPadding="false">

    <FrameLayout
        android:id="@+id/overlayContentPanel"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/bg_overlay_preview_panel"
        android:clipToOutline="true"
        android:padding="12dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="48dp">

                <LinearLayout
                    android:id="@+id/overlayDragHandle"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:layout_marginEnd="52dp"
                    android:background="?android:attr/selectableItemBackground"
                    android:clickable="true"
                    android:focusable="true"
                    android:gravity="center_vertical"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:includeFontPadding="false"
                        android:text="@string/overlay_preview_brand"
                        android:textColor="#FFF8EEF2"
                        android:textSize="15sp"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="3dp"
                        android:includeFontPadding="false"
                        android:text="@string/overlay_preview_product_name"
                        android:textColor="#FFCFC4CA"
                        android:textSize="11sp" />
                </LinearLayout>

                <TextView
                    android:id="@+id/overlayCloseButton"
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:layout_gravity="top|end"
                    android:background="@drawable/bg_overlay_preview_close"
                    android:clickable="true"
                    android:contentDescription="@string/overlay_preview_close"
                    android:focusable="true"
                    android:gravity="center"
                    android:includeFontPadding="false"
                    android:text="×"
                    android:textColor="#FFFFD9E3"
                    android:textSize="23sp"
                    android:textStyle="bold" />
            </FrameLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:paddingStart="4dp"
                android:paddingEnd="4dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:includeFontPadding="false"
                    android:text="@string/overlay_adjust_alpha_label"
                    android:textColor="#FFCFC4CA"
                    android:textSize="10sp" />

                <SeekBar
                    android:id="@+id/overlayAlphaSlider"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="4dp"
                    android:layout_weight="1"
                    android:max="100"
                    android:min="30"
                    android:progress="100"
                    android:progressTint="#FFB1C4D7"
                    android:thumbTint="#FFB1C4D7" />

                <TextView
                    android:id="@+id/overlayAlphaValue"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="4dp"
                    android:includeFontPadding="false"
                    android:text="100%"
                    android:textColor="#FFCFC4CA"
                    android:textSize="10sp" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:background="@drawable/bg_overlay_preview_status"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:paddingStart="8dp"
                android:paddingTop="4dp"
                android:paddingEnd="8dp"
                android:paddingBottom="4dp">

                <View
                    android:layout_width="7dp"
                    android:layout_height="7dp"
                    android:background="#FFFFA9C0" />

                <TextView
                    android:id="@+id/overlayStatusText"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="6dp"
                    android:includeFontPadding="false"
                    android:text="@string/overlay_preview_status"
                    android:textColor="#FFFFC8D7"
                    android:textSize="11sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <TextView
                android:id="@+id/overlayStartAnalysis"
                android:layout_width="match_parent"
                android:layout_height="44dp"
                android:layout_marginTop="11dp"
                android:background="@drawable/bg_overlay_analysis_button"
                android:clickable="true"
                android:focusable="true"
                android:gravity="center"
                android:includeFontPadding="false"
                android:text="@string/overlay_analysis_start"
                android:textColor="#FF30151E"
                android:textSize="13sp"
                android:textStyle="bold" />

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:layout_marginTop="11dp"
                android:background="#24FFFFFF" />

            <TextView
                android:id="@+id/overlayCommunityQq"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:background="@drawable/bg_overlay_text_link"
                android:clickable="true"
                android:contentDescription="@string/community_qq_content_description"
                android:ellipsize="end"
                android:focusable="true"
                android:gravity="center_vertical"
                android:includeFontPadding="false"
                android:maxLines="2"
                android:minHeight="42dp"
                android:paddingStart="9dp"
                android:paddingTop="5dp"
                android:paddingEnd="9dp"
                android:paddingBottom="5dp"
                android:text="@string/overlay_community_qq"
                android:textColor="#FFFFB1C4"
                android:textSize="12sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/overlayCommunityTelegram"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:background="@drawable/bg_overlay_text_link"
                android:clickable="true"
                android:contentDescription="@string/community_telegram_content_description"
                android:ellipsize="end"
                android:focusable="true"
                android:gravity="center_vertical"
                android:includeFontPadding="false"
                android:maxLines="2"
                android:minHeight="40dp"
                android:paddingStart="9dp"
                android:paddingTop="5dp"
                android:paddingEnd="9dp"
                android:paddingBottom="5dp"
                android:text="@string/overlay_community_telegram"
                android:textColor="#FFCFC4CA"
                android:textSize="12sp" />

            <!-- ===== 自动操作控件区 ===== -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:paddingStart="4dp"
                android:paddingEnd="4dp">

                <androidx.appcompat.widget.SwitchCompat
                    android:id="@+id/overlayAutoOpSwitch"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textOn="自动操作"
                    android:textOff="自动操作"
                    android:textColor="#FFCFC4CA"
                    android:textSize="11sp" />

                <TextView
                    android:id="@+id/overlayAutoOpStatus"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="4dp"
                    android:layout_weight="1"
                    android:includeFontPadding="false"
                    android:text="@string/overlay_auto_op_status_disabled"
                    android:textColor="#FFCFC4CA"
                    android:textSize="10sp" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:paddingStart="4dp"
                android:paddingEnd="4dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:includeFontPadding="false"
                    android:text="@string/overlay_auto_op_delay_label"
                    android:textColor="#FFCFC4CA"
                    android:textSize="10sp" />

                <SeekBar
                    android:id="@+id/overlayAutoOpDelaySlider"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="4dp"
                    android:layout_weight="1"
                    android:max="50"
                    android:progress="10"
                    android:progressTint="#FFB1C4D7"
                    android:thumbTint="#FFB1C4D7" />

                <TextView
                    android:id="@+id/overlayAutoOpDelayValue"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="4dp"
                    android:includeFontPadding="false"
                    android:text="100 ms"
                    android:textColor="#FFCFC4CA"
                    android:textSize="10sp" />
            </LinearLayout>

            <!-- ===== HUD 显示区（默认隐藏，开始执行后显示） ===== -->
            <FrameLayout
                android:id="@+id/overlayHudContainer"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:visibility="gone">

                <top.azek431.hzzs.ui.overlay.HUDCanvasView
                    android:id="@+id/overlayHudCanvas"
                    android:layout_width="match_parent"
                    android:layout_height="120dp"
                    android:background="#1A1A2E" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:orientation="vertical"
                    android:padding="4dp">

                    <TextView
                        android:id="@+id/overlayHudSceneText"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:includeFontPadding="false"
                        android:text="--"
                        android:textColor="#FFFFFFFF"
                        android:textSize="10sp" />

                    <TextView
                        android:id="@+id/overlayHudPoseText"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:includeFontPadding="false"
                        android:text="--"
                        android:textColor="#FFFFFFFF"
                        android:textSize="10sp" />

                    <TextView
                        android:id="@+id/overlayHudJumpStageText"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:includeFontPadding="false"
                        android:text="--"
                        android:textColor="#FFFFFFFF"
                        android:textSize="10sp" />

                    <TextView
                        android:id="@+id/overlayHudHazardsText"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:includeFontPadding="false"
                        android:text="--"
                        android:textColor="#FFFFFFFF"
                        android:textSize="10sp" />

                    <TextView
                        android:id="@+id/overlayHudCollectiblesText"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:includeFontPadding="false"
                        android:text="--"
                        android:textColor="#FFFFFFFF"
                        android:textSize="10sp" />

                    <TextView
                        android:id="@+id/overlayHudPromptIcon"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:includeFontPadding="false"
                        android:text=""
                        android:textColor="#FFFFFFFF"
                        android:textSize="12sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/overlayHudPromptText"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:includeFontPadding="false"
                        android:text="等待分析..."
                        android:textColor="#FFFFFFFF"
                        android:textSize="10sp" />

                    <TextView
                        android:id="@+id/overlayHudEtaText"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:includeFontPadding="false"
                        android:text=""
                        android:textColor="#FFFFFFFF"
                        android:textSize="10sp" />
                </LinearLayout>
            </FrameLayout>
        </LinearLayout>
    </FrameLayout>

    <TextView
        android:id="@+id/overlayResizeHandle"
        android:layout_width="32dp"
        android:layout_height="32dp"
        android:layout_gravity="bottom|end"
        android:layout_margin="4dp"
        android:background="@drawable/bg_overlay_preview_close"
        android:clickable="true"
        android:contentDescription="@string/overlay_resize_handle_content_description"
        android:focusable="true"
        android:gravity="center"
        android:includeFontPadding="false"
        android:text="↘"
        android:textColor="#FFFFD9E3"
        android:textSize="15sp"
        android:textStyle="bold" />

</FrameLayout>