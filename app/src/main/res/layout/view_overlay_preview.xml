<?xml version="1.0" encoding="utf-8"?>
<FrameLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="208dp"
    android:layout_height="wrap_content"
    android:background="@drawable/bg_overlay_preview_panel"
    android:clipToOutline="true"
    android:padding="12dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <LinearLayout
            android:id="@+id/overlayDragHandle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingBottom="6dp">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/overlay_preview_brand"
                    android:textColor="#FFF8EEF2"
                    android:textSize="15sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="1dp"
                    android:text="@string/overlay_preview_product_name"
                    android:textColor="#FFCFC4CA"
                    android:textSize="11sp" />

            </LinearLayout>

            <TextView
                android:id="@+id/overlayCloseButton"
                android:layout_width="30dp"
                android:layout_height="30dp"
                android:background="@drawable/bg_overlay_preview_close"
                android:clickable="true"
                android:contentDescription="@string/overlay_preview_close"
                android:focusable="true"
                android:gravity="center"
                android:text="×"
                android:textColor="#FFFFD9E3"
                android:textSize="20sp"
                android:textStyle="bold" />

        </LinearLayout>

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:background="@drawable/bg_overlay_preview_status"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingStart="8dp"
            android:paddingTop="4dp"
            android:paddingEnd="8dp"
            android:paddingBottom="4dp">

            <View
                android:layout_width="7dp"
                android:layout_height="7dp"
                android:background="#FFFFA9C0" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="6dp"
                android:text="@string/overlay_preview_status"
                android:textColor="#FFFFC8D7"
                android:textSize="11sp"
                android:textStyle="bold" />

        </LinearLayout>

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:layout_marginTop="10dp"
            android:background="#24FFFFFF" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:text="@string/overlay_community_title"
            android:textColor="#FFF8EEF2"
            android:textSize="12sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/overlayCommunityQq"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:background="@drawable/bg_overlay_preview_community_action"
            android:clickable="true"
            android:focusable="true"
            android:gravity="center_vertical"
            android:minHeight="42dp"
            android:paddingStart="10dp"
            android:paddingTop="9dp"
            android:paddingEnd="10dp"
            android:paddingBottom="9dp"
            android:text="@string/overlay_community_qq"
            android:textColor="#FFFFD9E3"
            android:textSize="12sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/overlayCommunityTelegram"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:background="@drawable/bg_overlay_preview_community_action"
            android:clickable="true"
            android:focusable="true"
            android:gravity="center_vertical"
            android:minHeight="42dp"
            android:paddingStart="10dp"
            android:paddingTop="9dp"
            android:paddingEnd="10dp"
            android:paddingBottom="9dp"
            android:text="@string/overlay_community_telegram"
            android:textColor="#FFFFD9E3"
            android:textSize="12sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:lineSpacingExtra="2dp"
            android:text="@string/overlay_community_hint"
            android:textColor="#FFCFC4CA"
            android:textSize="10sp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="@string/overlay_preview_drag_hint"
            android:textColor="#FF9F969B"
            android:textSize="10sp" />

    </LinearLayout>

</FrameLayout>
