<?xml version="1.0" encoding="utf-8"?>
<FrameLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="228dp"
    android:layout_height="wrap_content"
    android:background="@drawable/bg_overlay_preview_panel"
    android:clipToOutline="true"
    android:padding="12dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="48dp">

            <LinearLayout
                android:id="@+id/overlayDragHandle"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:layout_marginEnd="50dp"
                android:gravity="center_vertical"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:includeFontPadding="false"
                    android:text="@string/overlay_preview_brand"
                    android:textColor="#FFF8EEF2"
                    android:textSize="15sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="3dp"
                    android:includeFontPadding="false"
                    android:text="@string/overlay_preview_product_name"
                    android:textColor="#FFCFC4CA"
                    android:textSize="11sp" />

            </LinearLayout>

            <TextView
                android:id="@+id/overlayCloseButton"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:layout_gravity="top|end"
                android:background="@drawable/bg_overlay_preview_close"
                android:clickable="true"
                android:contentDescription="@string/overlay_preview_close"
                android:focusable="true"
                android:gravity="center"
                android:includeFontPadding="false"
                android:text="×"
                android:textColor="#FFFFD9E3"
                android:textSize="23sp"
                android:textStyle="bold" />

        </FrameLayout>

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="3dp"
            android:background="@drawable/bg_overlay_preview_status"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingStart="8dp"
            android:paddingTop="4dp"
            android:paddingEnd="8dp"
            android:paddingBottom="4dp">

            <View
                android:layout_width="7dp"
                android:layout_height="7dp"
                android:background="#FFFFA9C0" />

            <TextView
                android:id="@+id/overlayStatusText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="6dp"
                android:includeFontPadding="false"
                android:text="@string/overlay_preview_status"
                android:textColor="#FFFFC8D7"
                android:textSize="11sp"
                android:textStyle="bold" />

        </LinearLayout>

        <TextView
            android:id="@+id/overlayStartAnalysis"
            android:layout_width="match_parent"
            android:layout_height="44dp"
            android:layout_marginTop="11dp"
            android:background="@drawable/bg_overlay_analysis_button"
            android:clickable="true"
            android:focusable="true"
            android:gravity="center"
            android:includeFontPadding="false"
            android:text="@string/overlay_analysis_start"
            android:textColor="#FF30151E"
            android:textSize="13sp"
            android:textStyle="bold" />

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:layout_marginTop="11dp"
            android:background="#24FFFFFF" />

        <TextView
            android:id="@+id/overlayCommunityQq"
            android:layout_width="match_parent"
            android:layout_height="40dp"
            android:layout_marginTop="8dp"
            android:background="@drawable/bg_overlay_text_link"
            android:clickable="true"
            android:contentDescription="@string/community_qq_content_description"
            android:ellipsize="end"
            android:focusable="true"
            android:gravity="center_vertical"
            android:includeFontPadding="false"
            android:paddingStart="9dp"
            android:paddingEnd="9dp"
            android:singleLine="true"
            android:text="@string/overlay_community_qq"
            android:textColor="#FFFFB1C4"
            android:textSize="12sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/overlayCommunityTelegram"
            android:layout_width="match_parent"
            android:layout_height="38dp"
            android:layout_marginTop="2dp"
            android:background="@drawable/bg_overlay_text_link"
            android:clickable="true"
            android:contentDescription="@string/community_telegram_content_description"
            android:ellipsize="end"
            android:focusable="true"
            android:gravity="center_vertical"
            android:includeFontPadding="false"
            android:paddingStart="9dp"
            android:paddingEnd="9dp"
            android:singleLine="true"
            android:text="@string/overlay_community_telegram"
            android:textColor="#FFCFC4CA"
            android:textSize="12sp" />

    </LinearLayout>

</FrameLayout>
