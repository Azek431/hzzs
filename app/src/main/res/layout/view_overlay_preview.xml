<?xml version="1.0" encoding="utf-8"?>
<!--
    悬浮窗预览面板布局文件。

    此布局作为 WindowManager 悬浮窗显示，包含以下区域：
    1. 拖动手柄（overlayDragHandle）— 顶部区域，用于拖动移动窗口
    2. 关闭按钮（overlayCloseButton）— 右上角 × 按钮
    3. 透明度滑块（overlayAlphaSlider）— 调节悬浮窗整体透明度（30%~100%）
    4. 状态指示（overlayStatusText）— 显示当前状态（悬浮窗预览/执行中）
    5. 分析按钮（overlayStartAnalysis）— 切换执行状态（当前仅占位）
    6. 社区链接（overlayCommunityQq / overlayCommunityTelegram）— 跳转 QQ 群和 Telegram
    7. 调整手柄（overlayResize*）— 边缘和四角的透明点击区域，预留窗口缩放功能

    触摸优先级：
    - 拖动手柄（overlayDragHandle）优先级最高，覆盖大部分顶部区域
    - 关闭按钮在右上角，不与拖动手柄冲突
    - 边缘调整手柄（24dp 宽）在四周，不影响主要内容区域
    - 其余控件（滑块、按钮、链接）位于内容面板内，不影响拖动

    坐标系统：
    - 所有布局尺寸使用 dp/sp 单位
    - 窗口宽度固定为 228dp（由 OverlayPreviewManager 设置）
    - 内容面板有 12dp 内边距
    - 调整手柄有 12dp 外围 padding 环
-->
<FrameLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:id="@+id/overlayRootPanel">

    <!-- 12dp 外围 padding 环，为四边和四角的调整手柄提供命中区域 -->
    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:padding="12dp">

        <!-- 左侧调整手柄（顶部 | 左侧）— 预留窗口缩放功能 -->
        <View
            android:id="@+id/overlayResizeLeft"
            android:layout_width="24dp"
            android:layout_height="match_parent"
            android:layout_gravity="start|center_vertical"
            android:background="?android:attr/selectableItemBackgroundBorderless"
            android:contentDescription="@string/overlay_resize_left" />

        <!-- 顶部调整手柄（顶部 | 居中）— 预留窗口缩放功能 -->
        <View
            android:id="@+id/overlayResizeTop"
            android:layout_width="match_parent"
            android:layout_height="24dp"
            android:layout_gravity="top|center_horizontal"
            android:background="?android:attr/selectableItemBackgroundBorderless"
            android:contentDescription="@string/overlay_resize_top" />

        <!-- 右侧调整手柄（顶部 | 右侧）— 预留窗口缩放功能 -->
        <View
            android:id="@+id/overlayResizeRight"
            android:layout_width="24dp"
            android:layout_height="match_parent"
            android:layout_gravity="end|center_vertical"
            android:background="?android:attr/selectableItemBackgroundBorderless"
            android:contentDescription="@string/overlay_resize_right" />

        <!-- 底部调整手柄（底部 | 居中）— 预留窗口缩放功能 -->
        <View
            android:id="@+id/overlayResizeBottom"
            android:layout_width="match_parent"
            android:layout_height="24dp"
            android:layout_gravity="bottom|center_horizontal"
            android:background="?android:attr/selectableItemBackgroundBorderless"
            android:contentDescription="@string/overlay_resize_bottom" />

        <!-- 左上角调整手柄 — 预留窗口缩放功能 -->
        <View
            android:id="@+id/overlayResizeTopLeft"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:layout_gravity="top|start"
            android:background="?android:attr/selectableItemBackgroundBorderless"
            android:contentDescription="@string/overlay_resize_top_left" />

        <!-- 右上角调整手柄 — 预留窗口缩放功能 -->
        <View
            android:id="@+id/overlayResizeTopRight"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:layout_gravity="top|end"
            android:background="?android:attr/selectableItemBackgroundBorderless"
            android:contentDescription="@string/overlay_resize_top_right" />

        <!-- 左下角调整手柄 — 预留窗口缩放功能 -->
        <View
            android:id="@+id/overlayResizeBottomLeft"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:layout_gravity="bottom|start"
            android:background="?android:attr/selectableItemBackgroundBorderless"
            android:contentDescription="@string/overlay_resize_bottom_left" />

        <!-- 右下角调整手柄 — 预留窗口缩放功能 -->
        <View
            android:id="@+id/overlayResizeBottomRight"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:layout_gravity="bottom|end"
            android:background="?android:attr/selectableItemBackgroundBorderless"
            android:contentDescription="@string/overlay_resize_bottom_right" />

        <!-- 实际内容面板：包含品牌、滑块、状态、按钮、社区链接 -->
        <!-- 使用 FrameLayout + 圆角 drawable 背景替代 MaterialCardView，
             避免 WindowManager overlay 中 inflate 时 MaterialCardView 对
             Theme.MaterialComponents 的主题校验失败。 -->
        <FrameLayout
            android:id="@+id/overlayContentPanel"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_overlay_preview_card">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="12dp">

                <!-- 拖动手柄 + 关闭按钮行 -->
                <FrameLayout
                    android:layout_width="match_parent"
                    android:layout_height="48dp">

                    <!-- 拖动手柄：占据除关闭按钮外的顶部区域，用于拖动移动悬浮窗 -->
                    <LinearLayout
                        android:id="@+id/overlayDragHandle"
                        android:layout_width="match_parent"
                        android:layout_height="48dp"
                        android:layout_marginEnd="52dp"
                        android:gravity="center_vertical"
                        android:orientation="vertical">

                        <!-- 品牌缩写 "HZZS" -->
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:includeFontPadding="false"
                            android:text="@string/overlay_preview_brand"
                            android:textColor="#FFF8EEF2"
                            android:textSize="15sp"
                            android:textStyle="bold" />

                        <!-- 产品名称 "火崽崽助手" -->
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="3dp"
                            android:includeFontPadding="false"
                            android:text="@string/overlay_preview_product_name"
                            android:textColor="#FFCFC4CA"
                            android:textSize="11sp" />

                    </LinearLayout>

                    <!-- 关闭按钮：右上角 × 符号，点击后调用 OverlayPreviewManager.hide() -->
                    <TextView
                        android:id="@+id/overlayCloseButton"
                        android:layout_width="48dp"
                        android:layout_height="48dp"
                        android:layout_gravity="top|end"
                        android:background="@drawable/bg_overlay_preview_close"
                        android:clickable="true"
                        android:contentDescription="@string/overlay_preview_close"
                        android:focusable="true"
                        android:gravity="center"
                        android:includeFontPadding="false"
                        android:text="@string/overlay_close_button"
                        android:textColor="#FFFFD9E3"
                        android:textSize="23sp"
                        android:textStyle="bold" />

                </FrameLayout>

                <!-- 透明度滑块行：标签 + SeekBar + 百分比显示 -->
                <!-- SeekBar 范围 30~100，默认 100，实时影响整个悬浮窗的 alpha 值 -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:paddingStart="4dp"
                    android:paddingEnd="4dp">

                    <!-- 透明度标签 -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:includeFontPadding="false"
                        android:text="@string/overlay_adjust_alpha_label"
                        android:textColor="#FFCFC4CA"
                        android:textSize="10sp" />

                    <!-- 透明度滑块：0~100 映射到 0.0~1.0 的 alpha 值 -->
                    <SeekBar
                        android:id="@+id/overlayAlphaSlider"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="4dp"
                        android:layout_weight="1"
                        android:max="100"
                        android:min="30"
                        android:progress="100"
                        android:progressTint="#FFB1C4D7"
                        android:thumbTint="#FFB1C4D7" />

                    <!-- 透明度数值显示 -->
                    <TextView
                        android:id="@+id/overlayAlphaValue"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="4dp"
                        android:includeFontPadding="false"
                        android:text="@string/overlay_alpha_value_default"
                        android:textColor="#FFCFC4CA"
                        android:textSize="10sp" />

                </LinearLayout>

                <!-- 窗口大小调整提示（替代旧的缩放滑块） -->
                <TextView
                    android:id="@+id/overlaySizeHint"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:layout_marginStart="4dp"
                    android:includeFontPadding="false"
                    android:text="@string/overlay_adjust_window_hint"
                    android:textColor="#80CFC4CA"
                    android:textSize="9sp" />

                <!-- 状态指示器：小圆点 + 状态文字 -->
                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:background="@drawable/bg_overlay_preview_status"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:paddingStart="8dp"
                    android:paddingTop="4dp"
                    android:paddingEnd="8dp"
                    android:paddingBottom="4dp">

                    <!-- 状态指示灯：粉色圆点，表示当前状态 -->
                    <View
                        android:layout_width="7dp"
                        android:layout_height="7dp"
                        android:background="#FFFFA9C0" />

                    <!-- 状态文字：显示"悬浮窗预览"或"执行中" -->
                    <TextView
                        android:id="@+id/overlayStatusText"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="6dp"
                        android:includeFontPadding="false"
                        android:text="@string/overlay_preview_status"
                        android:textColor="#FFFFC8D7"
                        android:textSize="11sp"
                        android:textStyle="bold" />

                </LinearLayout>

                <!-- 分析执行按钮：切换"开始执行"/"点击结束执行"状态 -->
                <TextView
                    android:id="@+id/overlayStartAnalysis"
                    android:layout_width="match_parent"
                    android:layout_height="44dp"
                    android:layout_marginTop="11dp"
                    android:background="@drawable/bg_overlay_analysis_button"
                    android:clickable="true"
                    android:focusable="true"
                    android:gravity="center"
                    android:includeFontPadding="false"
                    android:text="@string/overlay_analysis_start"
                    android:textColor="#FF30151E"
                    android:textSize="13sp"
                    android:textStyle="bold" />

                <!-- HUD 信息区域（执行中可见） -->
                <LinearLayout
                    android:id="@+id/overlayHudContainer"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:orientation="vertical"
                    android:visibility="gone">

                    <!-- Canvas 绘制区：模拟游戏画面，标注玩家和危险物 -->
                    <top.azek431.hzzs.HUDCanvasView
                        android:id="@+id/overlayHudCanvas"
                        android:layout_width="match_parent"
                        android:layout_height="60dp"
                        android:background="#1AFFFFFF" />

                    <!-- 场景模式 + 角色姿态行 -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:gravity="center_vertical"
                        android:orientation="horizontal">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:includeFontPadding="false"
                            android:text="@string/hud_scene_label"
                            android:textColor="#FFB1C4D7"
                            android:textSize="9sp" />

                        <TextView
                            android:id="@+id/overlayHudSceneText"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:includeFontPadding="false"
                            android:text="--"
                            android:textColor="#FFFFC8D7"
                            android:textSize="9sp" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:includeFontPadding="false"
                            android:text="@string/hud_pose_label"
                            android:textColor="#FFB1C4D7"
                            android:textSize="9sp" />

                        <TextView
                            android:id="@+id/overlayHudPoseText"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:includeFontPadding="false"
                            android:text="--"
                            android:textColor="#FFFFC8D7"
                            android:textSize="9sp" />
                    </LinearLayout>

                    <!-- 跳跃阶段 + 危险物数量行 -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="2dp"
                        android:gravity="center_vertical"
                        android:orientation="horizontal">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:includeFontPadding="false"
                            android:text="跳段："
                            android:textColor="#FFB1C4D7"
                            android:textSize="9sp" />

                        <TextView
                            android:id="@+id/overlayHudJumpStageText"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:includeFontPadding="false"
                            android:text="0"
                            android:textColor="#FFFFC8D7"
                            android:textSize="9sp" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:includeFontPadding="false"
                            android:text="危险："
                            android:textColor="#FFB1C4D7"
                            android:textSize="9sp" />

                        <TextView
                            android:id="@+id/overlayHudHazardsText"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:includeFontPadding="false"
                            android:text="0"
                            android:textColor="#FFFFC8D7"
                            android:textSize="9sp" />
                    </LinearLayout>

                    <!-- 收藏物数量行 -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="2dp"
                        android:gravity="center_vertical"
                        android:orientation="horizontal">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:includeFontPadding="false"
                            android:text="收藏："
                            android:textColor="#FFB1C4D7"
                            android:textSize="9sp" />

                        <TextView
                            android:id="@+id/overlayHudCollectiblesText"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:includeFontPadding="false"
                            android:text="0"
                            android:textColor="#FFFFC8D7"
                            android:textSize="9sp" />
                    </LinearLayout>

                    <!-- HUD 动作提示行（高亮显示） -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="6dp"
                        android:background="@drawable/bg_overlay_analysis_button"
                        android:gravity="center"
                        android:orientation="horizontal"
                        android:paddingTop="6dp"
                        android:paddingBottom="6dp">

                        <TextView
                            android:id="@+id/overlayHudPromptIcon"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:includeFontPadding="false"
                            android:text=""
                            android:textColor="#FFFFD9E3"
                            android:textSize="14sp" />

                        <TextView
                            android:id="@+id/overlayHudPromptText"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="6dp"
                            android:includeFontPadding="false"
                            android:text="--"
                            android:textColor="#FF30151E"
                            android:textSize="11sp"
                            android:textStyle="bold" />

                        <TextView
                            android:id="@+id/overlayHudEtaText"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="8dp"
                            android:includeFontPadding="false"
                            android:text=""
                            android:textColor="#FFB1C4D7"
                            android:textSize="10sp" />
                    </LinearLayout>
                </LinearLayout>

                <!-- 分隔线 -->
                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:layout_marginTop="11dp"
                    android:background="#24FFFFFF" />

                <!-- 社区 QQ 群链接：点击打开 HZZS QQ 群 -->
                <TextView
                    android:id="@+id/overlayCommunityQq"
                    android:layout_width="match_parent"
                    android:layout_height="42dp"
                    android:layout_marginTop="8dp"
                    android:background="@drawable/bg_overlay_text_link"
                    android:clickable="true"
                    android:contentDescription="@string/community_qq_content_description"
                    android:ellipsize="end"
                    android:focusable="true"
                    android:gravity="center_vertical"
                    android:includeFontPadding="false"
                    android:paddingStart="9dp"
                    android:paddingEnd="9dp"
                    android:singleLine="true"
                    android:text="@string/overlay_community_qq"
                    android:textColor="#FFFFB1C4"
                    android:textSize="12sp"
                    android:textStyle="bold" />

                <!-- 社区 Telegram 频道链接：点击打开 Azek431 Telegram 主频道 -->
                <TextView
                    android:id="@+id/overlayCommunityTelegram"
                    android:layout_width="match_parent"
                    android:layout_height="40dp"
                    android:layout_marginTop="2dp"
                    android:background="@drawable/bg_overlay_text_link"
                    android:clickable="true"
                    android:contentDescription="@string/community_telegram_content_description"
                    android:ellipsize="end"
                    android:focusable="true"
                    android:gravity="center_vertical"
                    android:includeFontPadding="false"
                    android:paddingStart="9dp"
                    android:paddingEnd="9dp"
                    android:singleLine="true"
                    android:text="@string/overlay_community_telegram"
                    android:textColor="#FFCFC4CA"
                    android:textSize="12sp" />

            </LinearLayout>

            <!-- 右下角缩放手柄：长按触发缩放模式，拖动调整悬浮窗大小 -->
            <View
                android:id="@+id/overlayResizeHandle"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:layout_gravity="bottom|end"
                android:layout_margin="8dp"
                android:background="@drawable/bg_overlay_resize_handle"
                android:clickable="true"
                android:focusable="true"
                android:contentDescription="@string/overlay_resize_handle_content_description" />

        </FrameLayout>
    </FrameLayout>

</FrameLayout>
