<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/overlayCard"
    android:layout_width="@dimen/overlay_width"
    android:layout_height="wrap_content"
    android:clickable="true"
    android:focusable="true"
    app:cardBackgroundColor="@color/overlay_card_background"
    app:cardCornerRadius="@dimen/overlay_corner_radius"
    app:cardElevation="8dp"
    app:strokeColor="@color/outline_variant"
    app:strokeWidth="@dimen/stroke_width">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="@dimen/overlay_padding">

        <!-- Header row -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/overlay_panel_title"
                android:textColor="@color/overlay_text_primary"
                android:textSize="@dimen/overlay_text_title"
                android:textStyle="bold" />

            <ImageButton
                android:id="@+id/btnCloseOverlay"
                android:layout_width="@dimen/overlay_close_button_size"
                android:layout_height="@dimen/overlay_close_button_size"
                android:layout_marginStart="@dimen/space_xs"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="@string/action_close_overlay"
                android:src="@android:drawable/ic_menu_close_clear_cancel"
                android:tint="@color/overlay_close_tint" />

        </LinearLayout>

        <!-- Status chip -->
        <com.google.android.material.chip.Chip
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/space_sm"
            android:checkable="false"
            android:clickable="false"
            android:focusable="false"
            android:text="@string/overlay_panel_status"
            android:textColor="@color/status_preparing_on_container"
            app:chipBackgroundColor="@color/status_preparing_container"
            app:chipStrokeColor="@color/status_preparing_outline"
            app:chipStrokeWidth="@dimen/stroke_width"
            app:chipMinHeight="24dp" />

        <!-- Description -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/space_sm"
            android:text="@string/overlay_panel_description"
            android:textColor="@color/overlay_text_primary"
            android:textSize="@dimen/overlay_text_desc" />

        <!-- Note -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/space_2xs"
            android:text="@string/overlay_panel_note"
            android:textColor="@color/overlay_text_secondary"
            android:textSize="@dimen/overlay_text_note" />

    </LinearLayout>

</com.google.android.material.card.MaterialCardView>
