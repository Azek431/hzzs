<?xml version="1.0" encoding="utf-8"?>
<!--
    尺寸资源文件：所有 UI 元素的间距、字体大小、圆角半径等。

    命名规范：
    - space_*：通用间距（2xs=2dp, xs=4dp, sm=8dp, md=12dp, lg=16dp, xl=24dp, 2xl=32dp, 3xl=40dp）
    - page_*：页面级别的间距
    - top_bar_*：顶部标题栏相关尺寸
    - card_*：卡片相关尺寸
    - button_min_height：按钮最小高度（Material Design 建议 48dp）
    - feature_*：功能卡片的图标和间距
    - radius_*：圆角半径（small=12dp, medium=16dp, large=24dp）
    - stroke_width：描边宽度
    - text_*：字体大小（app_title, subtitle, hero_title, section_title, card_title, body, label, footer）
    - overlay_*：悬浮窗面板的尺寸定义（宽度、圆角、内边距、按钮大小、文字大小）

    所有尺寸使用 dp/sp 单位，确保在不同 DPI 设备上保持一致的视觉大小。
-->
<resources>

    <!-- Spacing -->
    <dimen name="space_2xs">2dp</dimen>
    <dimen name="space_xs">4dp</dimen>
    <dimen name="space_sm">8dp</dimen>
    <dimen name="space_md">12dp</dimen>
    <dimen name="space_lg">16dp</dimen>
    <dimen name="space_xl">24dp</dimen>
    <dimen name="space_2xl">32dp</dimen>
    <dimen name="space_3xl">40dp</dimen>

    <!-- Screen and components -->
    <dimen name="page_padding_horizontal">20dp</dimen>
    <dimen name="page_padding_bottom">32dp</dimen>
    <dimen name="top_bar_min_height">64dp</dimen>
    <dimen name="top_bar_padding_top">8dp</dimen>
    <dimen name="top_bar_padding_bottom">14dp</dimen>
    <dimen name="card_padding">20dp</dimen>
    <dimen name="feature_card_padding">16dp</dimen>
    <dimen name="button_min_height">48dp</dimen>
    <dimen name="feature_icon_container_size">40dp</dimen>
    <dimen name="feature_icon_size">22dp</dimen>

    <!-- Shape -->
    <dimen name="radius_small">12dp</dimen>
    <dimen name="radius_medium">16dp</dimen>
    <dimen name="radius_large">24dp</dimen>
    <dimen name="stroke_width">1dp</dimen>

    <!-- Typography -->
    <dimen name="text_app_title">23sp</dimen>
    <dimen name="text_app_subtitle">12sp</dimen>
    <dimen name="text_hero_title">25sp</dimen>
    <dimen name="text_section_title">16sp</dimen>
    <dimen name="text_card_title">17sp</dimen>
    <dimen name="text_body">14sp</dimen>
    <dimen name="text_label">12sp</dimen>
    <dimen name="text_footer">12sp</dimen>
    <dimen name="text_footer_small">11sp</dimen>
    <dimen name="text_line_spacing">3dp</dimen>

    <!-- Overlay panel -->
    <dimen name="overlay_width">260dp</dimen>
    <dimen name="overlay_corner_radius">16dp</dimen>
    <dimen name="overlay_padding">14dp</dimen>
    <dimen name="overlay_close_button_size">32dp</dimen>
    <dimen name="overlay_text_title">14sp</dimen>
    <dimen name="overlay_text_status">12sp</dimen>
    <dimen name="overlay_text_desc">11sp</dimen>
    <dimen name="overlay_text_note">10sp</dimen>

</resources>