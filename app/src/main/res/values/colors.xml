<?xml version="1.0" encoding="utf-8"?>
<!--
    颜色资源文件：HZZS 应用 Material Design 3 (M3) 浅色主题配色方案。

    配色体系：
    - surface_*：背景色系（从浅到深：background → surface → container_low → container → container_high → container_highest）
    - on_surface/*：前景文字和图标颜色
    - brand_*：品牌色（珊瑚红/玫瑰红 #C73650），用于主按钮、图标、强调色
    - status_preparing_*：准备中状态的黄色系（警告/中性状态）
    - outline/*：边框和分隔线颜色
    - feature_icon_*：功能卡片图标容器颜色
    - planned_*：暂未启用功能的灰度配色
    - overlay_*：悬浮窗面板专用配色

    品牌色选择珊瑚红 (#C73650) 的原因：
    - 与"火崽崽"的游戏 IP 色调一致（火焰/珊瑚色）
    - 在浅色背景 (#FFF8F6) 上有足够的对比度
    - 传递活力、热情的感觉，符合跑酷游戏的调性
-->
<resources>

    <!-- Core surfaces (light M3) -->
    <color name="surface_background">#FFF8F6</color>
    <color name="surface">#FFFDFC</color>
    <color name="surface_container_low">#FFFAF9</color>
    <color name="surface_container">#F7F2EE</color>
    <color name="surface_container_high">#F0EAE5</color>
    <color name="surface_container_highest">#E9E2DC</color>

    <!-- Brand: coral red / rose -->
    <color name="brand_primary">#C73650</color>
    <color name="brand_on_primary">#FFFFFF</color>
    <color name="brand_primary_container">#FFD9DE</color>
    <color name="brand_on_primary_container">#610D26</color>

    <!-- Status: preparing (light) -->
    <color name="status_preparing_container">#FFF8E1</color>
    <color name="status_preparing_on_container">#7A6200</color>
    <color name="status_preparing_outline">#C8B472</color>

    <!-- Text and outlines (light) -->
    <color name="on_surface">#1F1816</color>
    <color name="on_surface_variant">#5F5553</color>
    <color name="outline">#938886</color>
    <color name="outline_variant">#D7C2C5</color>
    <color name="divider">#E0D5D3</color>

    <!-- Feature icon containers (light) -->
    <color name="feature_icon_container">#FCE4EC</color>
    <color name="feature_icon_tint">#C73650</color>

    <!-- Disabled / planned state (light) -->
    <color name="planned_container">#F5EDEA</color>
    <color name="planned_on_container">#7A6E6B</color>
    <color name="planned_outline">#D0C4C2</color>

    <!-- Overlay card (light) -->
    <color name="overlay_card_background">#FFFFFF</color>
    <color name="overlay_text_primary">#1F1816</color>
    <color name="overlay_text_secondary">#5F5553</color>
    <color name="overlay_close_tint">#5F5553</color>

</resources>