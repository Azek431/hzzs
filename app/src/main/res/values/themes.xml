<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Dark Material Design 3 theme -->
    <style name="Theme.HuoZaiZaiAssistant" parent="Theme.Material3.DayNight.NoActionBar">
        <!-- Primary brand color -->
        <item name="colorPrimary">@color/brand_primary</item>
        <item name="colorOnPrimary">@color/brand_on_primary</item>
        <item name="colorPrimaryContainer">@color/brand_container</item>
        <item name="colorOnPrimaryContainer">@color/brand_on_container</item>

        <!-- Surface colors -->
        <item name="android:colorBackground">@color/surface</item>
        <item name="colorSurface">@color/surface</item>
        <item name="colorOnSurface">@color/on_surface</item>
        <item name="colorSurfaceVariant">@color/surface_variant</item>
        <item name="colorOnSurfaceVariant">@color/on_surface_variant</item>

        <!-- Outline -->
        <item name="colorOutline">@color/outline</item>
        <item name="colorOutlineVariant">@color/outline_variant</item>

        <!-- Status bar: dark icons on dark background → use surface_dim -->
        <item name="android:statusBarColor">@color/surface_dim</item>
        <item name="android:windowLightStatusBar" tools:targetApi="m">false</item>

        <!-- Hide window overlay -->
        <item name="android:windowDrawsSystemBarBackgrounds">true</item>
        <item name="android:navigationBarColor">@color/surface_dim</item>
        <item name="android:windowLightNavigationBar" tools:targetApi="27">false</item>
    </style>
</resources>
