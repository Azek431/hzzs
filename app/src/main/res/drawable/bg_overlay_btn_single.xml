<?xml version="1.0" encoding="utf-8"?>
<!--
    悬浮窗面板"单次执行"按钮背景：霓虹青科技风三态 selector。

    状态：
    - disabled（不可用时）：半透明青蓝 #4420B2AA
    - pressed（按下时）：亮霓虹青 #FF48D1CC，提供按压反馈
    - default（默认）：标准青蓝 #FF20B2AA

    圆角 10dp。
    使用场景：view_overlay_preview.xml 中的 overlayBtnSingle
-->
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_enabled="false">
        <shape>
            <solid android:color="#4420B2AA" />
            <corners android:radius="10dp" />
        </shape>
    </item>

    <item android:state_pressed="true">
        <shape>
            <solid android:color="#FF48D1CC" />
            <corners android:radius="10dp" />
        </shape>
    </item>

    <item>
        <shape>
            <solid android:color="#FF20B2AA" />
            <corners android:radius="10dp" />
        </shape>
    </item>
</selector>
