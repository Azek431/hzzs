<?xml version="1.0" encoding="utf-8"?>
<!--
    社区链接背景（页脚 QQ/Telegram 按钮）：selector 状态切换。

    状态：
    - pressed（按下时）：半透明粉色 #20FFB1C4 背景 + 10dp 圆角
    - default（默认）：完全透明 #00000000，不遮挡文字

    使用场景：view_community_footer.xml 中的 textCommunityQqLink / textCommunityTelegramLink
-->
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_pressed="true">
        <shape>
            <solid android:color="#20FFB1C4" />
            <corners android:radius="10dp" />
        </shape>
    </item>

    <item>
        <shape>
            <solid android:color="#00000000" />
            <corners android:radius="10dp" />
        </shape>
    </item>
</selector>
