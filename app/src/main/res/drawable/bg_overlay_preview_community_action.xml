<?xml version="1.0" encoding="utf-8"?>
<!--
    悬浮窗面板社区操作区域背景：两态 selector（用于 QQ/Telegram 链接行）。

    状态：
    - pressed（按下时）：半透明粉色 #49FFB1C4，提供按压反馈
    - default（默认）：微透明白色 #2BFFFFFF + 粉色描边 #55FFB1C4，
      形成卡片式边框效果

    圆角 12dp。
    注意：此 drawable 当前未在布局中直接使用，可能是预留或历史遗留。
-->
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_pressed="true">
        <shape>
            <solid android:color="#49FFB1C4" />
            <corners android:radius="12dp" />
        </shape>
    </item>

    <item>
        <shape>
            <solid android:color="#2BFFFFFF" />
            <corners android:radius="12dp" />
            <stroke
                android:width="1dp"
                android:color="#55FFB1C4" />
        </shape>
    </item>
</selector>
