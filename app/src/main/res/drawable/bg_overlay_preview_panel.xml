<?xml version="1.0" encoding="utf-8"?>
<!--
    悬浮窗面板整体背景：深色科技风卡片。

    参数：
    - 填充色 #F00D1117：深空蓝黑，近似 GitHub Dark 主题底色
    - 圆角 14dp：现代圆角风格
    使用场景：view_overlay_preview.xml 中的 overlayContentPanel
-->
<shape xmlns:android="http://schemas.android.com/apk/res/android"
    android:shape="rectangle">
    <solid android:color="#F00D1117" />
    <corners android:radius="14dp" />
    <stroke
        android:width="1dp"
        android:color="#3A7DDC" />
</shape>
