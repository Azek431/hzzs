<?xml version="1.0" encoding="utf-8"?>
<!--
    悬浮窗预览面板背景：带圆角的深色卡片背景。

    替代 MaterialCardView，避免 WindowManager overlay 中 inflate 时
    因主题不是 Theme.MaterialComponents 而导致 MaterialCardView 校验失败。

    颜色 #F019171D 是半透明深紫黑，与悬浮窗内所有粉红色文字配色一致。
    圆角 16dp 与 overlay_corner_radius 保持一致。
-->
<shape xmlns:android="http://schemas.android.com/apk/res/android"
    android:shape="rectangle">
    <solid android:color="#F019171D" />
    <corners android:radius="16dp" />
</shape>
