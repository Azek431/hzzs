<?xml version="1.0" encoding="utf-8"?>
<!--
    悬浮窗文本链接背景：两态 selector（QQ/Telegram 链接行），深色科技风。

    状态：
    - pressed（按下时）：霓虹蓝半透明 #223A7DDC，提供按压反馈
    - default（默认）：完全透明 #00000000，不抢文字焦点

    圆角 8dp。
    使用场景：view_overlay_preview.xml 中的 overlayCommunityQq / overlayCommunityTelegram
-->
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_pressed="true">
        <shape>
            <solid android:color="#223A7DDC" />
            <corners android:radius="8dp" />
        </shape>
    </item>

    <item>
        <shape>
            <solid android:color="#00000000" />
            <corners android:radius="8dp" />
        </shape>
    </item>
</selector>
