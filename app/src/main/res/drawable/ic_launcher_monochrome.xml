<!-- 应用图标前景层：火崽崽角色形象（白色圆角矩形底）。
     与 ic_launcher_background.xml 组合成自适应图标。
     108x108dp 视口，角色居中显示。
     注意：此为自适应图标前景，背景在 ic_launcher_background.xml 中。
-->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="108"
    android:viewportHeight="108">
    <!-- 白色圆角矩形底 -->
    <path
        android:fillColor="#FFFFFF"
        android:pathData="M19,19h70c10.49,0 19,8.51 19,19v32c0,10.49 -8.51,19 -19,19H38C27.51,89 19,80.49 19,69V38C19,27.51 27.51,19 38,19h51z" />
    <!-- 角色图片居中缩放 -->
    <group
        android:translateX="18"
        android:translateY="18"
        android:scaleX="0.6667"
        android:scaleY="0.6667">
        <bitmap
            android:src="@mipmap/ic_launcher_foreground_bitmap"
            android:gravity="center" />
    </group>
</vector>
