<?xml version="1.0" encoding="utf-8"?>
<!--
    悬浮窗面板"循环执行"按钮背景：霓虹蓝科技风三态 selector。

    状态：
    - disabled（不可用时）：半透明深蓝 #443A7DDC
    - pressed（按下时）：亮霓虹蓝 #FF5CB8FF，提供按压反馈
    - default（默认）：标准霓虹蓝 #FF3A7DDC

    圆角 10dp。
    使用场景：view_overlay_preview.xml 中的 overlayBtnCycle
-->
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_enabled="false">
        <shape>
            <solid android:color="#443A7DDC" />
            <corners android:radius="10dp" />
        </shape>
    </item>

    <item android:state_pressed="true">
        <shape>
            <solid android:color="#FF5CB8FF" />
            <corners android:radius="10dp" />
        </shape>
    </item>

    <item>
        <shape>
            <solid android:color="#FF3A7DDC" />
            <corners android:radius="10dp" />
        </shape>
    </item>
</selector>
