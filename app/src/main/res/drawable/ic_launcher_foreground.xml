<!-- 应用图标前景层：火崽崽角色形象（白色圆角矩形底 + 角色图片）。
     与 ic_launcher_background.xml 组合成自适应图标。
     108x108dp 视口，角色居中显示。
     注意：此为自适应图标前景，背景在 ic_launcher_background.xml 中。
-->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="108"
    android:viewportHeight="108">
    <!-- 白色圆角矩形底（圆角半径 20dp） -->
    <path
        android:fillColor="#FFFFFF"
        android:pathData="M20,0h68c11.05,0 20,8.95 20,20v68c0,11.05 -8.95,20 -20,20H20C8.95,108 0,99.05 0,88V20C0,8.95 8.95,0 20,0z" />
    <!-- 角色图片（居中缩放） -->
    <group
        android:translateX="24"
        android:translateY="24">
        <scale
            android:scaleWidth="0.6667"
            android:scaleHeight="0.6667"
            android:pivotX="0"
            android:pivotY="0">
            <bitmap
                android:src="@drawable/ic_launcher_foreground_bitmap"
                android:gravity="center" />
        </scale>
    </group>
</vector>
