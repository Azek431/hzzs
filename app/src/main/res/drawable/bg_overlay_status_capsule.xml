<?xml version="1.0" encoding="utf-8"?>
<!--
    悬浮窗状态指示胶囊背景：霓虹发光效果。

    状态：
    - pressed（按下时）：霓虹蓝 #FF3A7DDC
    - default（默认）：深蓝透明 #CC0D1117 + 霓虹蓝描边

    圆角 999dp（胶囊形）。
    使用场景：view_overlay_preview.xml 中的 overlayStatusContainer
-->
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_pressed="true">
        <shape>
            <solid android:color="#FF3A7DDC" />
            <corners android:radius="999dp" />
        </shape>
    </item>

    <item>
        <shape>
            <solid android:color="#CC0D1117" />
            <corners android:radius="999dp" />
            <stroke
                android:width="1dp"
                android:color="#3A7DDC" />
        </shape>
    </item>
</selector>
