# 本地 Release 签名配置模板（复制为 keystore.properties 后填写）。
# keystore.properties / signing.properties / local.secrets.properties 均已被 .gitignore。
# 切勿把填好密码的副本提交到 Git。
#
# 解析优先级（见 app/build.gradle.kts）：
#   1. 环境变量 ANDROID_KEYSTORE_*（CI 推荐）
#   2. 历史环境变量 AZEK431_RELEASE_*
#   3. 本文件中的键

# 密钥库绝对路径（示例为本机常见位置，请按实际修改）
storeFile=D:/Azek431-Secrets/AndroidSigning/azek431-android-release.p12

# 密钥库密码 / 密钥别名 / 密钥密码
storePassword=CHANGE_ME
keyAlias=CHANGE_ME
keyPassword=CHANGE_ME
